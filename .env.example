# ============================================================
#  Flooting Boat - Environment Configuration
#  Copy to .env and fill in real values before deploying.
# ============================================================

# --- Flask ---
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000

# --- REQUIRED SECRETS (app will not start without these) ---
# Generate strong random values, e.g. python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
INGEST_API_KEY=change-me-to-a-long-random-string

# --- Login accounts (STRONGLY recommended to override in production) ---
ADMIN_EMAIL=admin@lakewatch.local
ADMIN_PASSWORD=change-this-admin-password
RESEARCHER_EMAIL=researcher@lakewatch.local
RESEARCHER_PASSWORD=change-this-researcher-password
VIEWER_EMAIL=viewer@lakewatch.local
VIEWER_PASSWORD=change-this-viewer-password

# --- Security tuning (optional) ---
# Secure cookies need HTTPS. Auto-on in production; set false only for local HTTP.
SESSION_COOKIE_SECURE=true
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=300

# --- Firebase (optional - enables persistent storage across restarts/workers) ---
FIREBASE_DATABASE_URL=https://your-project.firebasedatabase.app/
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
# OR: GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# --- Scaling ---
# Keep at 1 unless Firebase is configured (in-memory data is per-worker).
WEB_CONCURRENCY=1

# --- App ---
APP_NAME=Smart AI Lake Monitoring
